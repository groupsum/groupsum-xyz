{
    "host":  "groupsum.xyz",
    "zone":  "groupsum.xyz",
    "repository":  "groupsum/groupsum-xyz",
    "siteKind":  "mdwrk-lander",
    "orchestrator":  "npmctl",
    "dnsProvider":  "namecheap",
    "deployment":  "self-hosted-docker",
    "dockerService":  "groupsum-xyz",
    "records":  [
                    {
                        "type":  "A",
                        "host":  "@",
                        "value":  "SITE_SERVER_IP_SECRET",
                        "ttl":  300
                    },
                    {
                        "type":  "A",
                        "host":  "*",
                        "value":  "SITE_SERVER_IP_SECRET",
                        "ttl":  300
                    },
                    {
                        "type":  "CNAME",
                        "host":  "www",
                        "value":  "groupsum.xyz",
                        "ttl":  300
                    }
                ],
    "proxyManager":  {
                         "provider":  "nginx-proxy-manager",
                         "apiEndpoint":  "NPM_BASE_URL_SECRET"
                     }
}
